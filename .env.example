# MeuChat — variaveis de ambiente (copie para .env e preencha)
# NUNCA commitar o .env real.

# ===== App Meta (developers.facebook.com) =====
META_APP_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ===== Conta Instagram =====
IG_USERNAME=
IG_USER_ID=
IG_ACCESS_TOKEN=

# ===== OAuth =====
OAUTH_REDIRECT_URI=https://seu-app.vercel.app/api/instagram/callback

# ===== Webhook =====
WEBHOOK_VERIFY_TOKEN=

# ===== Sessao / Cron =====
# Gere valores aleatorios. No terminal: openssl rand -hex 24
SESSION_SECRET=
# Protege /api/cron/refresh-tokens
CRON_SECRET=

# ===== Supabase =====
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# ===== URL publica do app =====
APP_BASE_URL=https://seu-app.vercel.app
